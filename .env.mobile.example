# Opcional para builds que ainda queiram embutir um servidor padrão.
# O APK também permite configurar e salvar o servidor na primeira abertura.
# Em um celular Android, localhost é o próprio celular, não o PC.
API_HOST_PORT=3333
VITE_API_URL=http://192.168.0.10:3333/api
PUBLIC_API_URL=http://192.168.0.10:3333/api
ONLYOFFICE_DOCUMENT_SERVER_URL=http://192.168.0.10:8082
CORS_ORIGINS=https://localhost,http://localhost,http://127.0.0.1:5173,http://localhost:5173
