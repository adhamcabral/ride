# Ride local development

# API
API_HOST=0.0.0.0
API_PORT=3333
API_HOST_PORT=3333
API_BIND_ADDRESS=0.0.0.0
JSON_BODY_LIMIT=32mb

# PDF page renderer. Lower DPI opens large PDFs faster and uses less RAM.
PDF_RENDER_DPI=120
PDF_RENDER_MAX_BUFFER_MB=64

# Local storage for SQLite metadata, uploaded objects, backups and snapshots.
# When the API runs through npm workspaces this resolves to apps/api/data.
STORAGE_DIR=./data

# Host directory mounted inside the API container at /backups.
# In Settings > Backups, use /backups as the default backup location.
RIDE_BACKUP_DIR=./apps/api/data/backups

# Keep at least this many bytes free before accepting uploads.
RIDE_MIN_FREE_BYTES=536870912

# Public URLs
PUBLIC_APP_URL=https://127.0.0.1:3443
PUBLIC_API_URL=https://127.0.0.1:3443/api
VITE_API_URL=/api
CORS_ORIGINS=https://127.0.0.1:3443,https://localhost:3443,http://127.0.0.1:5173,http://localhost:5173

# HTTPS reverse proxy. Leave RIDE_HTTPS_HOSTS empty to auto-detect localhost
# and current LAN IPs, or set it explicitly to every IP/domain that will open Ride.
RIDE_HTTPS_PORT=3443
RIDE_HTTPS_BIND_ADDRESS=0.0.0.0
ONLYOFFICE_HTTPS_PORT=8443
ONLYOFFICE_HTTPS_BIND_ADDRESS=0.0.0.0
RIDE_HTTPS_HOSTS=
RIDE_TLS_CERT_FILE=ride-local.crt
RIDE_TLS_KEY_FILE=ride-local.key
RIDE_TLS_DAYS=825
RIDE_SKIP_CERT_GENERATION=false

# Docker Compose development ports and internal API URL used by ONLYOFFICE.
WEB_HOST_PORT=5173
WEB_BIND_ADDRESS=127.0.0.1
VITE_WEB_PORT=3443
DOCKER_PUBLIC_API_URL=http://api:3333/api
DOCKER_ONLYOFFICE_PROXY_TARGET=http://onlyoffice

# ONLYOFFICE Docs
# Browser URL used to load the editor.
ONLYOFFICE_DOCUMENT_SERVER_URL=https://127.0.0.1:8443
ONLYOFFICE_PORT=8082
ONLYOFFICE_BIND_ADDRESS=127.0.0.1
VITE_ONLYOFFICE_PORT=8082

# Local Docker image built by npm run dev / npm run docker:up.
ONLYOFFICE_IMAGE=ride/onlyoffice-documentserver:local
ONLYOFFICE_BASE_IMAGE=ride/onlyoffice-documentserver-base:local

# Used only by npm run docker:vendor-office to freeze the upstream base into docker/onlyoffice/vendor.
ONLYOFFICE_UPSTREAM_IMAGE=onlyoffice/documentserver:latest
ONLYOFFICE_VENDOR_TAR=docker/onlyoffice/vendor/documentserver.tar

# Development defaults for the current local integration.
# JWT can be enabled for production-like tests; use strong secrets outside local dev.
ONLYOFFICE_JWT_ENABLED=false
ONLYOFFICE_JWT_SECRET=change-me-in-production
RIDE_ACCESS_TICKET_SECRET=change-me-too
ONLYOFFICE_CALLBACK_ALLOWED_HOSTS=onlyoffice,ride-onlyoffice,api,ride-api,127.0.0.1,localhost
OFFICE_CALLBACK_MAX_BYTES=268435456

# Required for local-only Docker/Linux development so ONLYOFFICE can call the API on 127.0.0.1.
ONLYOFFICE_ALLOW_PRIVATE_IP=true
ONLYOFFICE_ALLOW_META_IP=true
